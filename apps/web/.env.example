# Core
NODE_ENV=development
APP_BASE_URL=http://127.0.0.1:3000
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/volleyball

# Auth.js
AUTH_SECRET=replace-with-random-secret
AUTH_TRUST_HOST=true
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_ID=
APPLE_SECRET=
EMAIL_FROM=noreply@example.com
RESEND_API_KEY=

# Jobs
PG_BOSS_DATABASE_URL=${DATABASE_URL}
CRON_SECRET=

# Service backend
SERVICE_BACKEND=auto
